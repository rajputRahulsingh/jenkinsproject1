pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'jdk21'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/rajputRahulsingh/jenkinsproject1.git'
            }
        }

        stage('Clean') {
            steps {
                dir('jenkinspractice') {
                    bat 'mvn clean'
                }
            }
        }

        stage('Compile') {
            steps {
                dir('jenkinspractice') {
                    bat 'mvn compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('jenkinspractice') {
                    bat 'mvn test'
                }
            }
        }

        stage('Package') {
            steps {
                dir('jenkinspractice') {
                    bat 'mvn package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('jenkinspractice') {
                    bat 'docker build -t cucumber-project .'
                }
            }
        }

        stage('Run Tests Inside Container') {
            steps {
                bat 'docker run --rm cucumber-project'
            }
        }
    }

    post {

        always {
            junit '**/target/surefire-reports/*.xml'
        }

        success {
            echo 'Build Successful'
        }

        failure {
            echo 'Build Failed'
        }
    }
}