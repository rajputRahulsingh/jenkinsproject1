pipeline {
agent any

tools {
    maven 'Maven3'
    jdk 'jdk21'
}

stages {

    stage('Checkout') {
        steps {
            git branch: 'main',
                url: 'https://github.com/rajputRahulsingh/jenkinsproject1.git'
        }
    }

    stage('Clean') {
        steps {
            dir('jenkinspractice') {
                bat 'mvn clean'
            }
        }
    }

    stage('Compile') {
        steps {
            dir('jenkinspractice') {
                bat 'mvn compile'
            }
        }
    }

    stage('Test') {
        steps {
            dir('jenkinspractice') {
                bat 'mvn test'
            }
        }
    }

    stage('Package') {
        steps {
            dir('jenkinspractice') {
                bat 'mvn package'
            }
        }
    }
}

post {

    success {
        echo 'Build Successful'
    }

    failure {
        echo 'Build Failed'
    }
}

}
